# =============================================================
# deals-monitor-bot — Environment Variables
# Copy this file to .env for local development
# Set these directly in Render dashboard for production
# =============================================================

# ── Telegram API (from https://my.telegram.org) ──────────────
API_ID=12345678
API_HASH=your_api_hash_here

# ── Pyrogram session string (run generate_session.py once) ───
STRING_SESSION=your_session_string_here

# ── Channels to monitor (comma-separated negative IDs) ───────
# Example: -1001234567890,-1009876543210
CHANNELS=-1001234567890,-1009876543210

# ── n8n webhook URL ──────────────────────────────────────────
# Format: https://your-n8n-instance.com/webhook/deals-monitor
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/deals-monitor

# ── Tuning (optional — defaults shown) ───────────────────────
POST_DELAY=3          # seconds between queue items
POLLING_INTERVAL=600  # seconds between polling backup cycles
POLLING_LIMIT=5       # messages to check per channel per cycle

# ── Set automatically by Render ──────────────────────────────
# PORT=10000
