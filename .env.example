# Telegram API (from https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Pyrogram session string (run generate_session.py to get this)
STRING_SESSION=your_session_string_here

# Comma-separated channel IDs to monitor (use negative IDs for channels)
# Example: -1001234567890,-1009876543210
CHANNELS=-1001234567890,-1009876543210

# Your output channel ID where affiliate posts will be sent
OUTPUT_CHANNEL_ID=-1002065122146

# n8n webhook URL (production URL from your n8n workflow)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/deals-monitor

# Delay between posts to output channel (seconds) — prevents rate limiting
POST_DELAY=3

# Polling backup interval (seconds) — fallback check every 10 minutes
POLLING_INTERVAL=600

# Number of recent messages to check per channel during polling
POLLING_LIMIT=5
